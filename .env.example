# =============================================================================
# SpringRoll House Receipt Scanner — Environment Variables
# =============================================================================
# Copy this to .env and fill in your values.
# DO NOT commit .env to git!

# ── Anthropic API (for Claude Vision receipt extraction) ──
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Google Sheets (Purchases Database) ──
# The spreadsheet ID from the Google Sheets URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
SPREADSHEET_ID=your-spreadsheet-id-here

# Path to Google Cloud service account credentials JSON file
# (must have Sheets API access and be shared as editor on the spreadsheet)
GOOGLE_SHEETS_CREDENTIALS_JSON=config/service_account.json

# ── API Authentication (optional, recommended for production) ──
# If set, all requests must include an X-API-Key header with this value.
SCANNER_API_KEY=

# ── Gmail Watcher (optional, for email receipt auto-processing) ──
# Path to Gmail OAuth2 credentials
GMAIL_CREDENTIALS_JSON=config/gmail_credentials.json

# The dedicated receipt email address to monitor
RECEIPT_EMAIL=springrollhouse.receipts@gmail.com
